+    def get_custom_op_layout_constraints(self, target):
+        # Check if the custom op has a fixed layout tag and return a layout
+        # constraint function that preserves stride order.
+        if not isinstance(target, torch._ops.OpOverload):
+            return None
+        if not hasattr(target, "_overloadpacket"):
+            return None
+        packet = target._overloadpacket
+        if hasattr(packet, "_fixed_layout_") and packet._fixed_layout_:
+            # Enforce layout of first input on output.
+            def constraint_(inputs, outputs):
+                for out in outputs:
+                    out.set_(inputs[0].get_size(),
+                             inputs[0].get_stride(),
+                             inputs[0].get_storage_offset())
+                return True
+            return constraint_
+        return None
+
