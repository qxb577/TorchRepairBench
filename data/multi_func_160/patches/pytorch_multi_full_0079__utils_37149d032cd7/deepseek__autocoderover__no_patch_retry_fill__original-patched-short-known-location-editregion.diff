+            new_tensor = torch.empty(self.size(), dtype=torch.uint8, device='cpu')
+        # Copy the underlying storage, respecting non_blocking.
+        new_tensor.storage().copy_(self, non_blocking=non_blocking)
+        return new_tensor.storage()
