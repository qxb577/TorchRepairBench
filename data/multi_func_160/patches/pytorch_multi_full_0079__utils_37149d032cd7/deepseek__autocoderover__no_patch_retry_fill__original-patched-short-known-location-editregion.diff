+        # CPU does not have a device module, so handle the copy directly.
+        # Use non_blocking to respect pinned memory behaviour.
+        if hasattr(self, 'dtype'):
+            # TypedStorage: allocate a tensor of the same dtype on CPU.
+            new_tensor = torch.empty(self.size(), dtype=self.dtype, device='cpu')
