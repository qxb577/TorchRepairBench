+def issubdtype(arg1, arg2):
+    from . import _dtypes_impl
+
+    if isinstance(arg1, type) and issubclass(arg1, generic):
+        abstract1 = arg1
+    else:
+        try:
+            dt = _dtypes_impl.dtype(arg1)
+        except TypeError:
+            return False
+        abstract1 = type(dt)
+    if isinstance(arg2, type) and issubclass(arg2, generic):
+        abstract2 = arg2
+    else:
+        try:
+            dt = _dtypes_impl.dtype(arg2)
+        except TypeError:
+            return False
+        abstract2 = type(dt)
+    return issubclass(abstract1, abstract2)
