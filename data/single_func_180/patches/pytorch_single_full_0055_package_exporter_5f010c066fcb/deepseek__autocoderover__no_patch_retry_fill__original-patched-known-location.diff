+    def save_source_file(self, module_name, src):
+        """Add the given source file as the module with the given name."""
+        if os.path.isdir(src):
+            for root, dirs, files in os.walk(src):
+                for file in files:
+                    if file.endswith(".py"):
+                        file_path = os.path.join(root, file)
+                        relative_path = os.path.relpath(file_path, src)
+                        dotted_name = module_name + "." + relative_path.replace(os.sep, ".")[:-3]
+                        with open(file_path, "rb") as f:
+                            self.save_source_string(dotted_name, f.read())
+        else:
+            with open(src, "rb") as f:
+                self.save_source_string(module_name, f.read())
