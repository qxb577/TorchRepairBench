+    def _install_unraisablehook(self):
+        import sys
+        self._original_unraisablehook = sys.unraisablehook
+        sys.unraisablehook = self._unraisablehook
+        self._unraisablehook_installed = True
+
+    def _unraisablehook(self, unraisable):
+        if not hasattr(self, '_unraisable_exceptions'):
+            self._unraisable_exceptions = []
+        self._unraisable_exceptions.append(unraisable.exc_value)
+
+    def assertNoUnraisable(self, func):
+        import sys
+        if not self._unraisablehook_installed:
+            self._install_unraisablehook()
+        func()
+        if hasattr(self, '_unraisable_exceptions') and self._unraisable_exceptions:
+            raise AssertionError(f"Unraisable exceptions occurred: {self._unraisable_exceptions}")
+
+
