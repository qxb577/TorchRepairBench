@@ -2115,10 +2117,32 @@ class TestCase(expecttest.TestCase):
         #       call in try-finally and always do the check.
         @wraps(method)
         def wrapper(self, *args, **kwargs):
+            if not self._unraisablehook_installed:
+                self._install_unraisablehook()
             with policy():
                 method(*args, **kwargs)
