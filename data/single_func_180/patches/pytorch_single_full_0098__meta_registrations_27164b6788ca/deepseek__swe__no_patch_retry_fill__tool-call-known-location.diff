+@register_meta(torch.ops.aten._native_multi_head_attention)
+def _(q, k, v, embed_dim, num_heads, qkv_weight, qkv_bias, proj_weight, proj_bias, key_padding_mask=None, need_weights=False, average_attn_weights=False, mask_type=0):
+    # attn_output shape is same as q
+    attn_output = q.new_empty(q.shape)
+    # attn_output_weights shape depends on need_weights and average_attn_weights
+    if need_weights:
+        if average_attn_weights:
+            weights_shape = (q.shape[0], q.shape[1], q.shape[1])
+        else:
+            weights_shape = (q.shape[0], num_heads, q.shape[1], q.shape[1])
+    else:
+        # Return a zero-size tensor when need_weights is False
+        weights_shape = (0,)
+    attn_output_weights = q.new_empty(weights_shape)
+    return attn_output, attn_output_weights
+
