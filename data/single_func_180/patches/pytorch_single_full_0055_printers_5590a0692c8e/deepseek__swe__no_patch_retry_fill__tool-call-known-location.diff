+    def _print_min_max(self, expr: sympy.Expr, func: str) -> str:
+        args = expr.args
+        if len(args) == 2:
+            casted = [f"static_cast<int64_t>({self._print(a)})" for a in args]
+            return f"std::{func}({', '.join(casted)})"
+        else:
+            printed = [self._print(a) for a in args]
+            return f"std::{func}<int64_t>({{{', '.join(printed)}}})"
+
+    def _print_Min(self, expr: sympy.Expr) -> str:
+        return self._print_min_max(expr, "min")
+
+    def _print_Max(self, expr: sympy.Expr) -> str:
+        return self._print_min_max(expr, "max")
