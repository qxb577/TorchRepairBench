+@register_meta(torch._native_multi_head_attention)
+def meta_native_multi_head_attention(
+    query,
+    key,
+    value,
+    embed_dim,
+    num_heads,
+    q_proj_weight,
+    q_proj_bias,
+    k_proj_weight,
+    k_proj_bias,
+    v_proj_weight,
+    v_proj_bias,
+    out_proj_weight,
+    out_proj_bias,
+    key_padding_mask=None,
+    need_weights=True,
+    average_attn_weights=True,
+    mask_type=None,
+):
+    B, L, E = query.shape
+    S = key.shape[1]
